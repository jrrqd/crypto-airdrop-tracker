{
"update_url": "https://clients2.google.com/service/update2/crx",

  "manifest_version": 3,
  "name": "Airdrop Tracker",
  "version": "1.0",
  "description": "Track the latest crypto airdrop schedules with a minimalistic interface",
  "permissions": [
    "storage",
    "activeTab",
    "alarms"
  ],
  "host_permissions": [
    "https://airdrops.io/*",
    "https://www.kucoin.com/*",
    "https://coinmarketcap.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Airdrop Tracker",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}

